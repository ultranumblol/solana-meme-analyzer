# Copy this file to .env for local testing (never commit .env to git)

# Your EVM wallet address to receive USDC payments on Base chain
PAY_TO_ADDRESS=0x1b9b6bc66ff25e767a226984f1e1337829152e35

# Price per API request in USDC (default: $0.02)
PRICE_PER_REQUEST=0.02

# Optional: Helius RPC key for better Solana node reliability
HELIUS_API_KEY=your_helius_key_here
